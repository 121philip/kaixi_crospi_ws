#!/bin/bash

#
# script to install eTaSL python driver in the current python environment
# give argument "NOQUESTIONS" if you want the script to continue without
# questions.
#
# E. Aertbelien (sept. 2021)
#
#BUILDDIR="/home/masterthesis/kaixi_crospi_ws/build/etasl_wrapper"
INSTALLDIR="/home/masterthesis/kaixi_crospi_ws/install/etasl_wrapper"
ETASLVERSION="1.5.0"

echo " "
echo "Install eTaSL ${ETASLVERSION}$ in the current python environment"
echo "----------------------------------------------------------------"
echo "optional arguments: " 
echo " NOQUESTIONS : continue without confirmation"
echo " MINIMAL     : only install the minimally required python packages"
echo " "
printf "Python environment to be used (empty= system dir. will be used) : \n  ${VIRTUAL_ENV}\n"
printf "Install directory of the eTaSL version belonging to this script :\n  ${INSTALLDIR}\n"
if [ "$1" != "NOQUESTIONS" ] && [ "$2" != "NOQUESTIONS" ] 
then
        read -p "Continue ? (Y/N) " -n 1 -r
        printf    # (optional) move to a new line
        if [[ $REPLY =~ ^[Yy]$ ]]
        then
            printf "continuing..."
        else
            exit 1
        fi
fi
#
# Creating of standard eTaSL environment
#
if [ $(type -t pip3) == "file" ] && [ $(type -t python3) == "file" ]
then
    echo "checking paths:"
    if [ "${VIRTUAL_ENV}" != "" ];
        if test -f "${VIRTUAL_ENV}/bin/python3";
        then
            echo "Ok. This is a python 3 environment"
        else
            echo "This is not a python 3 virtual environment.  If you use a virtual environment"
            echo "you have to use a python 3 virtual environment."
            echo "e.g.   mkvirtualenv -p python3 my_environment_name "
            return 
        fi
    then
        echo "Installing in a system directory.  Make sure that you have permission to write in the system directories!"
    fi
    which pip3
    which python
    echo "--------------"
    cd "${INSTALLDIR}/share/etasl_py";
    pip3 install --upgrade pip 
    pip3 install --upgrade virtualenvwrapper
    if [ "$1" != "MINIMAL" ] && [ "$2" != "MINIMAL" ] 
    then
        pip3 install -r requirements.txt
    else
        pip3 install -r requirements-minimal.txt
    fi
    python3 setup.py install
    if [ "${VIRTUAL_ENV}" != "" ];
    then
        echo "Installing postactivationhook because I am installing into virtual enviroment"
        cp "${INSTALLDIR}/bin/set_etasl_paths.sh" "${VIRTUAL_ENV}/bin"
        cp "${INSTALLDIR}/bin/remove_etasl_paths.sh" "${VIRTUAL_ENV}/bin"
        if [ "$(grep 'set_etasl_paths.sh' ${VIRTUAL_ENV}/bin/postactivate)" == "" ]
        then
            echo "installing eTaSL hook"
            echo -e "\nsource set_etasl_paths.sh\n" >> "${VIRTUAL_ENV}/bin/postactivate"
        else
            echo "eTaSL postactivate hook was already installed."
        fi
        if [ "$(grep 'remove_etasl_paths.sh' ${VIRTUAL_ENV}/bin/predeactivate)" == "" ]
        then
            echo "removing eTaSL hook"
            echo -e "\nsource remove_etasl_paths.sh\n" >> "${VIRTUAL_ENV}/bin/predeactivate"
        else
            echo "eTaSL deactivate hook was already installed."
        fi
        # execute this manually, because we are already inside the environment
        # and the adapted postactivate script is not yet executed:
        source "${INSTALLDIR}/bin/set_etasl_paths.sh"
    else
        echo "Did not install postactivation hook because I am installing in system directories."
    fi
else
    printf "Cancelled! Install python3 and pip3 in the used python environment and try again."
fi



